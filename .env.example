# ─── Flask ────────────────────────────────────────────────
# KÖTELEZŐ — ha hiányzik, az app nem indul (RuntimeError).
# Generálás: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-to-random-64-char-hex

# Dev módban 1, production-ben 0 (vagy kihagyni).
FLASK_DEBUG=0

# ─── PostgreSQL ───────────────────────────────────────────
DATABASE_URL=postgresql://zeghang:password@localhost:5432/zeghang

# ─── OpenAI (AI kategorizálás, duplikátum, tartalomszűrés) ─
# Opcionális — nélküle minden bejelentés "other" kategóriát kap.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ─── Brevo / Sendinblue (tranzakciós email) ───────────────
# Opcionális — nélküle a jelszó-emlékeztető és admin alert nem megy ki.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=zeghangja@proton.me
BREVO_SENDER_NAME=Zalaegerszeg Hangja

# ─── Web Push (VAPID) ─────────────────────────────────────
# Kulcsokat a setup-vapid.sh generálja. A push értesítések opcionálisak.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=zeghangja@proton.me

# ─── Admin riasztás célcíme ───────────────────────────────
# Ide megy a security_log Brevo alert (rate limit, shadowban, upload bomb stb.).
# Ha üres, nincs riasztás.
ADMIN_ALERT_EMAIL=

# ─── Kanonikus URL ────────────────────────────────────────
# sitemap.xml, canonical, og:url, og:image forrása.
# FONTOS: mindig HTTPS, és ne tartalmazzon trailing /-t.
SITE_URL=https://zeghangja.hu

# ─── Fájl feltöltés ───────────────────────────────────────
UPLOAD_DIR=/opt/zeghang/uploads
MAX_UPLOAD_MB=20

# ─── OpenWeatherMap (opcionális, fejlesztés alatt) ─────────
# OPENWEATHER_API_KEY=
